{
  "name": "smith-farms-etl-monitor-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Smith Farms ETL Monitor - Backend API",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
